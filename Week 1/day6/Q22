#include <iostream>
using namespace std;

int main()
{
    long long binary;
    int decimal=0,rem,base=1;

    cout<<"Enter a binary number: ";
    cin>>binary;

    while(binary>0)
    {
        rem=binary%10;
        decimal=decimal+rem*base;
        base=base*2;
        binary=binary/10;
    }

    cout<<"Decimal equivalent: "<<decimal;

    return 0;
}
