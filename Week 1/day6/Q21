#include <bits/stdc++.h>
using namespace std;

int main()
{
    int n, rem;
    long long binary=0,place=1;

    cout << "Enter a decimal number: ";
    cin >> n;

    while(n>0)
    {
        rem=n%2;
        binary=binary+rem*place;
        place=place*10;
        n=n/2;
    }

    cout<<"Binary equivalent: "<<binary;

    return 0;
}
