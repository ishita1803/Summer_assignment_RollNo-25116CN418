#include <bits/stdc++.h>
using namespace std;
int main() 
{
    int a,b, flag=0;
    cout<<"Enter the start of the range: ";
    cin>>a;
    cout<<"Enter the end of the range: ";
    cin>>b;
    for(int i=a;i<=b;i++)
    {
        flag=0;
        for(int j=2;j<i;j++)
        {
            if(i%j==0)
            flag++;
            break;
        }
    if(flag==0)
    cout<<i<<" is a prime number\n";
    }

    return 0;
}
