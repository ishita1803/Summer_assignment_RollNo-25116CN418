#include <bits/stdc++.h>
using namespace std;
int main() 
{
    int a,b, least=0;
    cout<<"Enter the first number: ";
    cin>>a;
    cout<<"Enter the second number: ";
    cin>>b;
    for(int i=1;i<=a*b;i++)
    {
        if(i%a==0&&i%b==0)
        {
            least=i;
            break;
        }
    }
    cout<<least<<" is the LCM of "<<a<<" and "<<b;

    return 0;
}
