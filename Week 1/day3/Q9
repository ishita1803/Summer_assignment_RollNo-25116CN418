#include <bits/stdc++.h>
using namespace std;
int main() 
{
    int n, flag=0;
    cout<<"Enter the number: ";
    cin>>n;
    for(int i=2;i<n;i++)
    {
        if(n%i==0)
        flag++;
        break;
    }
    if(flag==0)
    cout<<"Its a prime number";
    else
    cout<<"Its not a prime number";

    return 0;
}
