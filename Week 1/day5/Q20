#include <bits/stdc++.h>
using namespace std;
int main() 
{
    int n,flag=0,max=0;
    cout<<"Enter the number: ";
    cin>>n;
    for(int i=1;i<=n;i++)
    {
        if(n%i==0)
        {
            flag=0;
            for(int j=2;j<i;j++)
            {
                if(i%j==0)
                {
                    flag++;
                    break;
                }
            }
            if(flag==0)
            max=i;
        }
    }
    cout<<max<<" is the biggest prime factor";
return 0;
}
