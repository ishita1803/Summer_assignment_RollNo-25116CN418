#include <bits/stdc++.h>
using namespace std;

bool prime(int a)
{
    int flag=0;
    for(int i=2;i<a;i++)
    {
        if(a%i==0)
        {
            flag++;
            break;
        }
    }
    if(flag==0)
    return true;
    else
    return false;
}
int main()
{
    int a;
    cout<<"Enter the number: ";
    cin>>a;
    if(prime(a))
    cout<<a<<" is a prime number";
    else
    cout<<a<<" is not a prime number";
    return 0;
}
