#include <bits/stdc++.h>
using namespace std;

int fibo(int a)
{
    if(a==0)
    return 0;
    if(a==1)
    return 1;
    return fibo(a-1)+fibo(a-2);
    
}
int main()
{
    int a;
    cout<<"Enter the number of terms: ";
    cin>>a;
    for(int i=0;i<a;i++)
    {
        cout<<fibo(i)<<"\t";
    }
    return 0;
}
