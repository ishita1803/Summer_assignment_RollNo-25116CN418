#include <bits/stdc++.h>
using namespace std;
int main()
{
    int n;
    cout<<"Enter the total elements in array: ";
    cin>>n;
    int a[n];
    for(int i=0;i<n;i++)
    {
        cout<<"\nEnter the value for a["<<i<<"]: ";
        cin>>a[i];
    }
    int max=a[0];
    int min=a[0];
    for(int i=0;i<n;i++)
    {
        if(a[i]>max)
        max=a[i];
        if(a[i]<min)
        min=a[i];
    }
    cout<<"Maximum: "<<max;
    cout<<"\nMinimum= "<<min;
    return 0;
}
