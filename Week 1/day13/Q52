#include <bits/stdc++.h>
using namespace std;
int main()
{
    int n,even=0,odd=0;
    cout<<"Enter the total elements in array: ";
    cin>>n;
    int a[n];
    for(int i=0;i<n;i++)
    {
        cout<<"\nEnter the value for a["<<i<<"]: ";
        cin>>a[i];
        if(a[i]%2==0)
        even++;
        else
        odd++;
    }

    cout<<"Total odd elements "<<odd;
    cout<<"\nTotal even elements= "<<even;
    return 0;
}
