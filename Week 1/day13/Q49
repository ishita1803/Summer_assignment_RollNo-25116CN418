#include <bits/stdc++.h>
using namespace std;
int main()
{
    int n;
    cout<<"Enter the total elements in array: ";
    cin>>n;
    int a[n];
    for(int i=0;i<n;i++)
    {
        cout<<"\nEnter the value for a["<<i<<"]: ";
        cin>>a[i];
    }
    cout<<"Array: \n";
    for(int i=0;i<n;i++)
    {
        cout<<"a["<<i<<"]: "<<a[i]<<"\n";
    }
    return 0;
}
