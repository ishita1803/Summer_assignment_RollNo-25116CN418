#include <bits/stdc++.h>
using namespace std;
int main()
{
    int n,s,flag=0;
    cout<<"Enter the total elements in array: ";
    cin>>n;
    int a[n];
    for(int i=0;i<n;i++)
    {
        cout<<"\nEnter the value for a["<<i<<"]: ";
        cin>>a[i];
    }
    cout<<"Enter the element to be searched: ";
    cin>>s;
    for(int i=0;i<n;i++)
    {
        if(a[i]==s)
        {
            cout<<s<<" Found at index at "<<i;
            flag++;
            break;
        }
    }
    if(flag==0)
    cout<<"Not found";
    return 0;
}
