#include <bits/stdc++.h>
using namespace std;
int main()
{
    int n,s,f=0;
    cout<<"Enter the total elements in array: ";
    cin>>n;
    int a[n];
    for(int i=0;i<n;i++)
    {
        cout<<"\nEnter the value for a["<<i<<"]: ";
        cin>>a[i];
    }
    cout<<"Enter the element to count its frequency : ";
    cin>>s;
    for(int i=0;i<n;i++)
    {
        if(a[i]==s)
        {
            f++;
        }
    }
    cout<<"Frequency of "<<s<<" in the array is "<<f;
    return 0;
}
