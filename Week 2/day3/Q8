#include <iostream>
using namespace std;
int main()
{
    int n, d, s=0,t;
    cout<<"Enter the number";
    cin>>n;
    t=n;
    while(n>0)
    {
        d=n%10;
        s=s*10+d;
        n=n/10;
    }
    if(s==t)
    cout<<t<<" is palindrome";
    else
    cout<<t<<" is not palindrome";
    return 0;
}
